---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import About from '../components/About.astro'
import Software from '../components/Software.astro'
import Mobile from '../components/Mobile.astro'
import Showcase from '../components/Showcase.astro'
import How from '../components/How.astro'
import Economics from '../components/Economics.astro'
import Services from '../components/Services.astro'
import Store from '../components/Store.astro'
import Contact from '../components/Contact.astro'
import Footer from '../components/Footer.astro'
import Marquee from '../components/Marquee.astro'

const CAPABILITIES = [
  'MWD / LWD', 'Гамма-каротаж', 'Инклинометрия', 'Drill Monitor',
  'Декодирование сигнала', 'Сервис 24/7', 'Реестр отечественного ПО',
]
---

<Layout>
  <div class="bg-fx"></div>

  {/* Разметку рисует сервер, поведение — scripts/nav.js. */}
  <Nav />
  <main id="main">
    <Hero />
    <About />
    <Showcase />
    <Software />
    <Mobile />
    <Economics />
    <Marquee items={CAPABILITIES} theme="black" speed={45} />
    <How />
    <Services />
    <Store />
    <Contact />
  </main>
  <Footer />
</Layout>
