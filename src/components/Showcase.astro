---
import { asset } from '../lib/asset.js'

/* TODO: подписи описывают железо, а изображения — скриншоты приложения.
   Свериться с реальными фото продукции. */
const PRODUCTS = [
  {
    n: '01', img: '/direct.webp', title: 'Телеметрическая система MWD',
    text: 'Забойный модуль в немагнитной УБТ: три акселерометра и три магнитометра дают зенитный угол, азимут и положение отклонителя. Замер уходит наверх гидравлическим или электромагнитным каналом — без подъёма инструмента.',
    tags: ['MWD', 'Инклинометрия', '2 канала'],
  },
  {
    n: '02', img: '/earth.webp', title: 'Блок декодирования сигнала',
    text: 'Наземная часть комплекса: выделяет сигнал из шума буровых насосов, восстанавливает кадр телеметрии и раскладывает его на параметры. Готовые замеры идут на станцию геолога и в систему удалённого мониторинга.',
    tags: ['Декодер', 'Real-time'],
  },
  {
    n: '03', img: '/kitrent.webp', title: 'Датчики LWD',
    text: 'Меряют давление промывочной жидкости и температуру там, где работает электроника, — на забое, а не на устье. Перепад и нагрев видны раньше, чем перейдут в прихват, размыв промывочных каналов или отказ модуля.',
    tags: ['LWD', 'Сенсор', 'P / T'],
  },
  {
    n: '04', img: '/kit4psd.webp', title: 'Сервис и ЗИП',
    text: 'Склад запчастей по всем моделям: модули, кабельные сборки, уплотнения, расходники — отгрузка без ожидания производства. Ремонт и калибровка приборов, инженер на связи с бригадой круглосуточно.',
    tags: ['ЗИП', 'Сервис 24/7'],
  },
]

/* Линейка-«аккордеон»: карточки стоят в ряд равными долями, а под
   курсором нужная раскрывается на бо́льшую долю ряда — соседние
   сжимаются и гаснут. Фокус ведёт указатель, поэтому листалка со
   стрелками и перетаскиванием больше не нужна.

   Тот же эффект работает с клавиатуры (:focus-within), а на тач и при
   reduced-motion ряд превращается в обычную сетку плиток — раскрывать
   там нечего, наведения нет.

   Карточка — светлая панель, а не тёмная фотоплитка. Раньше кадр лежал
   на всю площадь под чёрным градиентом, потому что поверх него стоял
   белый текст. Но рендеры продукции сняты НА БЕЛОМ: притемнение уводило
   их фон в серую муть, а сам предмет — в неразличимость. Секция при
   этом стоит на светлой заливке (gray), и пять чёрных плиток читались
   чужим островом посреди неё.

   Поэтому кадр и подпись разведены: рендер остаётся в своей родной
   белой среде в верхней зоне, текст живёт под ним на панели. Тёмный
   градиент не нужен — накладки текста на изображение больше нет. */
---

<section id="products" data-theme="light">
  <div class="container">
    <div class="car-head">
      <div>
        <div class="eyebrow reveal"><span class="ey-no">04<span class="ey-den"> / 07</span></span>Линейка оборудования</div>
        <h2 class="h-title reveal">Оборудование <br />и сервис</h2>
        <p class="lead reveal">
          Полная линейка телеметрии MWD/LWD собственной разработки —
          от забойных датчиков до наземных станций декодирования и сервиса.
        </p>
      </div>
    </div>
  </div>

  <div class="exp-row reveal">
    {PRODUCTS.map((p) => (
      <article class="exp-card" tabindex="0">
        <div class="exp-frame instr-frame">
          <img class="exp-img" src={asset(p.img)} alt={p.title} loading="lazy" draggable="false" />
        </div>

        <div class="exp-body">
          <div class="exp-head">
            <span class="exp-num mono" aria-hidden="true">{p.n}</span>
            <span class="exp-spec mono">{p.tags.join(' · ')}</span>
            <h3 class="exp-title">{p.title}</h3>
          </div>
          <div class="exp-more">
            <div class="exp-more-in">
              <p class="exp-text">{p.text}</p>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
