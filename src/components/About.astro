---
import { asset } from '../lib/asset.js'

/* ─── «О компании» — одна сцена, всё движется вместе ───

   Раньше здесь стояли два раздела подряд: штабель «Ключевых цифр» и вслед
   отдельная сцена с земным шаром. Теперь это одна прибитая сцена, и —
   главное — акты не идут друг за другом, а разворачиваются одновременно
   по одному прогрессу прокрутки:

     • стеклянная карточка листает три факта;
     • снизу выходит и подрастает земной шар, доворачиваясь Россией;
     • чёрная заливка сгущается в синюю ночь — сцена и без того тёмная,
       глобус на своём холодном свете виден с самого начала прокрутки.

   Всё это concurrent: к финалу шар заполнил кадр, ночь в полную силу,
   показан последний факт. Карточка и заголовок не уходят — они лежат
   стеклом поверх наливающейся сцены. Стекло здесь оправдано тем, что
   под карточкой фон меняется, а стекло просто берёт то, что под ним.

   Разметка только раскладывает слои. Прогресс, листание, ночь и смену
   цвета текста ведёт scripts/aboutScene.js; земной шар — globeCanvas.js.
   Оба берут прогресс из одного модуля, поэтому не разъезжаются.

   Левая колонка и стеклянная карточка отвечают на разные вопросы и
   раньше стояли вперемешку («Ключевые цифры» заголовком над строкой
   про Россию) — коллега увидел глобус и не понял его смысла, подпись
   терялась. Теперь слева заголовок сцены — сама строка про Россию,
   с заливкой белым по мере прокрутки (тот же приём, что и ночь: не
   переключается классом, а наливается прогрессом); справа, прямо
   над карточкой фактов, — маленький кикер «Ключевые цифры», который
   эту карточку и подписывает. */
const FACTS = [
  {
    big: '15', unit: 'лет', kicker: 'На рынке телеметрии',
    text: 'Разрабатываем и производим системы MWD/LWD с 2010 года. Оборудование работает на объектах ведущих добывающих компаний России и СНГ.',
    img: '/t1.png',
  },
  {
    big: '200+', kicker: 'Скважин с MWD/LWD',
    text: 'Пробурено с нашими телесистемами — от наклонно-направленных до горизонтальных стволов сложного профиля.',
    img: '/t2.png',
  },
  {
    big: '24/7', kicker: 'Инженерная поддержка',
    text: 'Дежурная смена инженеров на связи круглосуточно, с удалённым доступом к данным буровой в реальном времени.',
    img: '/t3.png',
  },
]

const total = String(FACTS.length).padStart(2, '0')
---

<section id="about" data-theme="black">
  <div class="atlas" data-atlas>
    <div class="atlas-stage" data-atlas-stage>
      {/* Ночь. Отдельным слоем над заливкой и под шаром: прозрачность
          этого слоя наливает скролл покадрово, а не переключает классом. */}
      <div class="atlas-night" aria-hidden="true"></div>
      <canvas class="atlas-canvas" data-globe-canvas aria-hidden="true"></canvas>

      {/* Заголовок раздела — на месте всю сцену. Тёмный на светлом старте,
          к финалу перекрашивается в светлый под синей ночью (.is-night).

          Строка про Россию — теперь сам заголовок сцены (h2), не подпись
          под «Ключевыми цифрами»: раньше она шла вторым пунктом и терялась,
          коллега не связал глобус с текстом. Дублирующий span-оверлей —
          чисто визуальный слой заливки: он aria-hidden, читает текст
          screen reader ровно один раз (сам h2). Прогресс заливки ведёт
          aboutScene.js — тот же прогресс, что доворачивает глобус. */}
      <div class="atlas-copy">
        <div class="atlas-head">
          <div class="eyebrow"><span class="ey-no">01<span class="ey-den"> / 09</span></span>О компании</div>
          <h2 class="atlas-geo" data-atlas-geo>
            Реализуем проекты по всей России
            <span class="atlas-geo-fill" data-atlas-geo-fill aria-hidden="true">Реализуем проекты по всей России</span>
          </h2>
          <p class="lead">
            От Западной Сибири до шельфовых месторождений — с телеметрией
            и геонавигацией собственной разработки.
          </p>
          <a class="pill" href="#contact">связаться</a>
        </div>
      </div>

      <div class="atlas-deck">
        <span class="atlas-deck-kicker mono">Ключевые цифры</span>
        {/* Слот — grid в одну ячейку: карточки лежат друг на друге, высота
            слота равна самой высокой. Видима ровно одна — её ведёт скролл. */}
        <div class="atlas-slot">
          {FACTS.map((f, i) => (
            <article class="atlas-card" data-atlas-card={i} aria-hidden={i !== 0} inert={i !== 0}>
              <div class="ac-shot">
                <img src={asset(f.img)} alt="" loading="lazy" draggable="false" />
              </div>

              <div class="ac-body">
                <span class="ac-big">
                  {f.big}
                  {f.unit && <span class="ac-unit">{f.unit}</span>}
                </span>
                <span class="ac-kicker">{f.kicker}</span>
                <p class="ac-text">{f.text}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="atlas-bar">
          <span class="atlas-count mono" aria-hidden="true">
            <b data-atlas-count>01</b><i>/{total}</i>
          </span>

          {/* Стрелки не переключают карточку сами — они увозят страницу
              к нужной точке той же прокрутки (aboutScene.js). Иначе на
              странице оказалось бы два источника правды о текущем факте. */}
          <div class="atlas-nav">
            <button type="button" class="atlas-arrow" data-atlas-prev aria-label="Предыдущий факт">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button type="button" class="atlas-arrow" data-atlas-next aria-label="Следующий факт">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>
      </div>

      <span class="atlas-label mono" aria-hidden="true">География деятельности</span>
    </div>
  </div>
</section>
