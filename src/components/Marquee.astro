---
/* Бесконечная лента — «шов» между секциями вместо линии-разделителя.
   Список клонируется в motion.js; здесь только одна копия. */
const { items, theme = 'gray', dir = 'left', speed = 45 } = Astro.props
---

<div class="marquee" data-theme={theme} data-marquee-dir={dir} data-marquee-speed={speed}>
  <ul class="marquee-list" aria-hidden="true">
    {items.map((t) => (
      <li>
        {t}
        <span class="marquee-sep" aria-hidden="true">/</span>
      </li>
    ))}
  </ul>
</div>
