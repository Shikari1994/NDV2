---
import { asset } from '../lib/asset.js'

/* Плитки только настольной версии: мобильный клиент вынесен в отдельную
   секцию (Mobile.astro) и показан там во всю ширину. Плиткой он оставался
   бы одним скриншотом среди пяти, а это отдельный продукт. */
/* Пропорции кадров (ширина/высота) зашиты и в разметку (row), и в CSS
   (.bt-<key>) — оба места должны совпадать, если заменится скриншот.
   drilling 1.72:1 · survey 1.81:1 · bha 2.70:1 · logging 1.84:1 · park 2.26:1 */
const MODULES = [
  {
    key: 'drilling',
    n: '01',
    tab: 'Бурение',
    // единственный настоящий real-time монитор — только он носит бейдж LIVE
    live: true,
    img: '/app-drilling.webp',
    row: 'a',
    title: 'Мониторинг бурения в реальном времени',
    text: 'Единый пульт бурильщика: проходка, нагрузка на долото, момент, обороты, давление и вибрация — десятки каналов телеметрии с обновлением в реальном времени. Компас азимута и автоматическая SCC-коррекция.',
    tags: ['Real-time', 'Телеметрия MWD', 'Коррекция азимута'],
  },
  {
    key: 'survey',
    n: '02',
    tab: 'Инклинометрия',
    img: '/app-survey.webp',
    video: '/app-survey.mp4',
    row: 'a',
    title: 'Инклинометрия и 3D-траектория',
    tags: ['3D-ствол', 'План / факт'],
  },
  {
    key: 'bha',
    n: '04',
    tab: 'Оборудование',
    img: '/app-bha.webp',
    row: 'a',
    title: 'Компоновка КНБК и ресурс',
    text: 'Не только этот рейс — весь парк техники.',
    tags: ['КНБК / BHA', 'Ресурс до ТО'],
  },
  {
    key: 'logging',
    n: '03',
    tab: 'Каротаж',
    img: '/app-logging.webp',
    video: '/app-logging.mp4',
    row: 'b',
    title: 'Каротажный планшет LWD',
    tags: ['Гамма-каротаж', 'Экспорт LAS / PDF'],
  },
  {
    key: 'park',
    n: '05',
    tab: 'Паспорта',
    img: '/dd.png',
    row: 'b',
    title: 'Паспорт и наработка прибора',
    text: 'Живёт с прибором, а не со скважиной.',
    tags: ['Наработка', 'История рейсов', 'ЗИП'],
  },
]

/* Второй пласт раздела: то, что не видно на скриншотах, но чем система
   занята между рейсами. Мозаика показывает мониторинг — эти три пункта
   показывают учёт, и вместе они и есть полный цикл: прибор заведён в
   базу, наработка набежала сама, паспорт выгрузился готовым.

   Отдельным блоком, а не плитками: у него нет кадра, который стоило бы
   показать, а текст на 40 слов мелкая плитка не держит. */
const LIFECYCLE = [
  {
    n: '01',
    title: 'Общее хранилище оборудования',
    text: 'Каждый прибор, переводник и элемент КНБК заведён в базу один раз — с серийным номером, паспортными характеристиками и полной историей. Все подразделения работают с одним справочником, а не с десятком разрозненных таблиц: где сейчас прибор, в каком он рейсе и кто обслуживал его последним, видно из любого офиса.',
  },
  {
    n: '02',
    title: 'Наработка считается автоматически',
    text: 'Часы циркуляции и вращения, метры проходки, число рейсов и температурные режимы пишутся на конкретный серийный номер прямо из данных рейса — без журналов и ручного переноса. Система заранее предупреждает о подходе к ресурсу, поэтому ТО планируется до отказа, а не после него.',
  },
  {
    n: '03',
    title: 'Паспорта заполняются сами',
    text: 'Паспорт прибора собирается из уже накопленных данных: наработка, история ремонтов и калибровок, результаты последних рейсов. Готовый документ выгружается в PDF за секунды — вместо часов переписывания цифр из журналов в шаблон и расхождений между копиями.',
  },
]
---

<section id="software" data-theme="black">
  <div class="container">
    <div class="sw-head grid">
      <div>
        <div class="eyebrow reveal"><span class="ey-no">02<span class="ey-den"> / 07</span></span>Программный комплекс · настольная версия</div>
        <h2 class="h-title reveal">
          Drill&nbsp;Monitor — мониторинг <br />бурения в реальном времени
        </h2>
      </div>
      <div class="sw-head-side reveal">
        <p class="lead">
          Единая платформа для геонавигации: телеметрия MWD/LWD, инклинометрия,
          каротаж — и полный учёт парка оборудования с наработкой и паспортами.
          Один интерфейс на буровой, в офисе и на мобильном.
        </p>
        <div class="sw-actions">
          <a class="btn btn-primary" href="#contact">
            Запросить демо
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
          <a class="btn btn-ghost" href="#contact">Войти в систему</a>
        </div>
      </div>
    </div>

    <div class="sw-bento">
      {['a', 'b'].map((row) => (
        <div class={`bento-row bento-row-${row}`}>
          {MODULES.filter((m) => m.row === row).map((m) => (
            <article class={`bento-tile instr-frame bt-${m.key} ${m.key === 'drilling' ? 'is-feature' : ''} reveal`}>
              {m.video ? (
                <video
                  class="bento-shot"
                  poster={asset(m.img)}
                  data-lazy-video={asset(m.video)}
                  muted
                  loop
                  playsinline
                  preload="none"
                  aria-label={m.title}
                />
              ) : (
                <img class="bento-shot" src={asset(m.img)} alt={m.title} loading="lazy" />
              )}
              <div class="bento-bar">
                <span class="bento-kicker mono"><span class="bento-n">{m.n}</span> · {m.tab}</span>
                {m.live && <span class="bento-live"><span class="bento-live-dot" />LIVE</span>}
              </div>
              <div class="bento-body">
                <h3>{m.title}</h3>
                {m.text && <p>{m.text}</p>}
                <div class="tag-row">
                  {m.tags.map((t) => <span class="tag">{t}</span>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      ))}
    </div>

    <div class="sw-life">
      <div class="sw-life-head reveal">
        <span class="sw-life-kicker mono">Между рейсами</span>
        <h3 class="sw-life-title">
          От учёта до паспорта — без единой таблицы вручную
        </h3>
      </div>
      <div class="sw-life-grid">
        {LIFECYCLE.map((f) => (
          <div class="sw-life-item reveal">
            <span class="sw-life-n mono">{f.n}</span>
            <h4>{f.title}</h4>
            <p>{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
