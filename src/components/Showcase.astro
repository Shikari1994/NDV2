---
/* Три позиции — один в один со списком «Продукция» в D:\Projects\Dmit
   (GT-Navigator / Наземный комплекс / Модуль инклинометра): те же три
   модели, та же связка «название + короткая подпись + описание».
   «Сервис и ЗИП» как четвёртая карточка убран — это самостоятельная
   тема, которую отдельно и подробнее раскрывают Services.astro
   (ремонт/калибровка/супервайзинг) и Store.astro (витрина ЗИП),
   держать её здесь третьим слоем было лишним.

   specs — набор пар «label · value» на карточку, открывается боковой
   шторкой (см. specsDrawer.js). У «Модуля инклинометра» — те же
   акселерометры/магнитометры, что у Dmit: это отдельный съёмный узел
   для любой телесистемы линейки, а не дубль сенсора GT-Navigator. */
const PRODUCTS = [
  {
    id: 'mwd', n: '01', title: 'GT-Navigator', line: 'Телесистема MWD / LWD',
    text: 'Забойный модуль в немагнитной УБТ: три акселерометра и три магнитометра дают зенитный угол, азимут и положение отклонителя. Замер уходит наверх гидравлическим или электромагнитным каналом — без подъёма инструмента.',
    specs: [
      ['Рабочая температура', 'до +150 °C (опция +175 °C)'],
      ['Канал передачи данных', 'Гидравлический (пульсатор) / электромагнитный'],
      ['Датчики', '3 акселерометра + 3 магнитометра'],
      ['Совместимость', 'Немагнитная УБТ, стандартные типоразмеры'],
      ['Виброустойчивость', 'До 30 g'],
    ],
  },
  {
    id: 'decoder', n: '02', title: 'Наземный комплекс', line: 'Блок декодирования сигнала',
    text: 'Наземная часть комплекса: выделяет сигнал из шума буровых насосов, восстанавливает кадр телеметрии и раскладывает его на параметры. Готовые замеры идут на станцию геолога и в систему удалённого мониторинга.',
    specs: [
      ['Рабочая температура', 'от −40 °C до +60 °C'],
      ['Канал передачи данных', 'Проводной / радиоканал удалённого мониторинга'],
      ['Датчики', 'Промышленный монитор + коммуникатор, протокол WITSML'],
      ['Совместимость', 'Станция геолога, система удалённого мониторинга'],
      ['Виброустойчивость', 'Промышленный стандарт'],
    ],
  },
  {
    id: 'inclinometer', n: '03', title: 'Модуль инклинометра', line: 'MEMS-акселерометры и магнитометры',
    text: 'Отдельный инклинометрический модуль для интеграции в любую телесистему линейки GT: три MEMS-акселерометра и три MEMS-магнитометра дают зенитный угол и азимут независимо от остальной электроники. Экономичная схема и увеличенный запас по виброустойчивости держат точность даже при ударных нагрузках КНБК.',
    specs: [
      ['Рабочая температура', 'от −40 °C до +60 °C, стабильно на забое'],
      ['Канал передачи данных', 'Внутренняя шина телесистемы'],
      ['Датчики', '3 MEMS-акселерометра + 3 MEMS-магнитометра'],
      ['Совместимость', 'Любая телесистема линейки GT'],
      ['Виброустойчивость', 'До 50 g (ультимативная)'],
    ],
  },
]

/* Линейка — ряды во всю ширину, а не аккордеон фотокарточек: описание
   и ТТХ-кнопка видны сразу, без промежуточного hover-раскрытия, а клик
   по всей строке (это <button>, не просто div с onclick) сразу поднимает
   боковую шторку с ТТХ. Приём — прямой перенос секции «Продукция» из
   D:\Projects\Dmit, включая обособленную рамку каждой строки с зазором
   между ними и окантованную кнопку справа, но без чертёжных
   corner-marks и 3D-кнопки-куба (см. PRODUCT.md → Anti-references).

   Шапка (.prod-head) — тоже прямой перенос: заголовок в своей колонке
   слева, лид с волосяной вертикальной чертой и синим акцентом слева —
   в своей справа, вся шапка на подложке во всю ширину (не .container,
   не .car-head — оба варианта заголовка сайта держат лид под, а не
   рядом с заголовком). Секция стоит сразу после «О компании», по
   прямой просьбе. */
---

<section id="products" data-theme="black">
  <div class="prod-head">
    <div class="prod-head-title">
      <div class="eyebrow reveal"><span class="ey-no">02<span class="ey-den"> / 09</span></span>Линейка оборудования</div>
      <h2 class="h-title reveal">Оборудование <br />и сервис</h2>
    </div>
    <div class="prod-head-lead">
      <p class="lead reveal">
        Полная линейка телеметрии MWD/LWD собственной разработки —
        от забойных модулей до наземных станций декодирования
        и инклинометрических узлов.
      </p>
    </div>
  </div>

  <div class="rig-list reveal">
    {PRODUCTS.map((p) => (
      <button class="rig-row" data-specs-open={p.id} type="button">
        <span class="rig-num mono" aria-hidden="true">{p.n} /</span>
        <span class="rig-head">
          <span class="rig-title">{p.title}</span>
          <span class="rig-line mono">{p.line}</span>
        </span>
        <span class="rig-text">{p.text}</span>
        <span class="rig-cta mono">
          Смотреть ТТХ
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
        </span>
      </button>
    ))}
  </div>
</section>

{/* ── Шторка со спецификациями ──
    Одна шторка на всю линейку: панели лежат друг на друге (как
    .atlas-card в «О компании»), JS показывает нужную классом .is-on.
    Разметку и данные держит этот компонент — specsDrawer.js только
    переключает видимость и transform, не знает о содержимом. */}
<div class="specs-overlay" data-specs-overlay></div>
<aside class="specs-drawer glass" data-specs-drawer aria-hidden="true">
  <button class="specs-close" data-specs-close type="button" aria-label="Закрыть характеристики">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6L6 18" /></svg>
  </button>
  {PRODUCTS.map((p) => (
    <div class="specs-panel" data-specs-panel={p.id}>
      <span class="specs-eyebrow mono">Характеристики · {p.n}</span>
      <h3 class="specs-title">{p.title}</h3>
      <dl class="specs-list">
        {p.specs.map(([label, value]) => (
          <div class="specs-row">
            <dt>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))}
      </dl>
      <a class="btn btn-primary specs-cta" href="#contact" data-specs-close>
        Запросить ТЭО
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </a>
    </div>
  ))}
</aside>
