---
import '../index.css'
import { asset } from '../lib/asset.js'

const logoHref = asset('/logo.webp')

const {
  title = 'ГЕОТЕХНАВИГАЦИЯ — Телеметрия и геонавигация бурения',
  description = 'Разработка и производство телеметрического оборудования MWD/LWD и программного комплекса Drill Monitor для контроля траектории бурения в реальном времени.',
} = Astro.props

const canonical = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).href
  : Astro.url.pathname

// Один источник правды на оба тега ниже: <link> и его <noscript>-дубль
// обязаны запрашивать ровно тот же URL, иначе без JS приедет другой набор
// начертаний.
// Три гарнитуры вместо четырёх. Geologica и Golos Text заменены одним
// нейтральным гротеском (Inter) — швейцарский канон требует одной-двух
// гарнитур, а не набора близких по рисунку. Unbounded остался, но сжат
// до единственного начертания: после сужения его области до мега-заголовка
// колоды из пяти весов используется ровно один — 800.
const fontsHref =
  'https://fonts.googleapis.com/css2?family=Unbounded:wght@800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap'

const ogImage = Astro.site ? new URL(logoHref, Astro.site).href : logoHref

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ГЕОТЕХНАВИГАЦИЯ',
  url: canonical,
  logo: ogImage,
  description,
  areaServed: ['RU', 'СНГ'],
  knowsAbout: ['Телеметрия MWD/LWD', 'Геонавигация бурения', 'Программный комплекс Drill Monitor'],
}
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <!-- viewport-fit=cover обязателен: без него env(safe-area-inset-*) на iOS
         всегда ноль, и вся разметка полей под вырез — в --gut, в подвале
         экрана колоды, в футере — не действует. -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/webp" href={logoHref} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="theme-color" content="#07090d" />

    <!-- Preload картинки прибора снят: первый экран стал типографическим,
         его LCP — мега-заголовок, а не изображение. Грузить сюда скриншот
         значило бы отбирать полосу у шрифта, который LCP и рисует. -->

    <!-- Шрифты.
         Начертание Geologica 300 убрано: font-weight:300 в index.css не
         встречается ни разу, а браузерный дефолт такой вес не даёт — файл
         качался впустую.

         Таблица подключена не блокирующе: media="print" снимает её с
         критического пути, onload возвращает в дело. В URL стоит
         display=swap, то есть текст в любом случае сначала рисуется
         запасной гарнитурой и подменяется по приходу файла — приём лишь
         убирает ожидание ответа стороннего домена до первой отрисовки,
         конечный вид страницы тот же. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href={fontsHref}
      rel="stylesheet"
      media="print"
      onload="this.media='all';this.onload=null"
    />
    <noscript>
      <link href={fontsHref} rel="stylesheet" />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Перейти к содержимому</a>
    <slot />
    <!-- Шапка первой и отдельным файлом: бургер начинает нажиматься,
         не дожидаясь разбора Lenis и GSAP из motion.js. -->
    <script>
      import '../scripts/nav.js'
    </script>
    <!-- Остальное — одним тегом: раньше три отдельных <script> давали три
         бандла и три запроса, хотя модули независимы и нужны одновременно.
         Тяжёлое внутри по-прежнему грузится лениво: three.js и .glb
         подтягивает динамический import в globeCanvas.js. -->
    <script>
      import '../scripts/motion.js'
      import '../scripts/heroCanvas.js'
      import '../scripts/deckReadout.js'
      // aboutScene раньше globeCanvas: первый решает, прибивать ли сцену
      // (класс .is-static), второй по этому классу — поднимать ли three.js.
      import '../scripts/aboutScene.js'
      import '../scripts/globeCanvas.js'
    </script>
  </body>
</html>
