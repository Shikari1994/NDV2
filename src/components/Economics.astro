---
/* «Экономика бурения» — ROI-обоснование комплекса, которого раньше
   на странице не было: остальные секции отвечают на вопрос «что это»,
   эта — на вопрос «зачем это заказчику в деньгах и простоях».

   Три проблемы намеренно не оформлены как «шаги» (.step-node из
   How.astro): это не последовательность, а три независимых источника
   потерь, и нумерованный узел с соединительной линией здесь солгал бы
   о порядке. Вместо неё — тот же приём, что у .contact-card: колонки
   с волосяной отбивкой.

   Проблемы 01 и 02 сознательно перекликаются с тем, что уже обещает
   Software.astro («Общее хранилище оборудования», «Наработка считается
   автоматически») — это один и тот же ответ комплекса, показанный
   с двух сторон: там — что делает система, здесь — какую потерю она
   закрывает. Проблема 03 ссылается на ту же SCC-коррекцию, что уже
   упомянута в Software.astro («Компас азимута и автоматическая
   SCC-коррекция») — термин не изобретается заново для одной секции.

   TODO: цифры синергии (доля буровых на диспетчера, % снижения затрат
   на выездной персонал) — маркетинговая оценка, не измерение по
   реальному клиенту. Заменить или подтвердить перед публикацией. */
const PROBLEMS = [
  {
    kicker: 'Потеря 01 · фрагментация',
    title: 'Разрозненность систем',
    text: 'Когда инклинометрия, расчёт прочности колонны и учёт наработки приборов ведутся в разных программах, общая картина теряется — решения на буровой принимаются дольше и с меньшей уверенностью.',
  },
  {
    kicker: 'Потеря 02 · ручной ввод',
    title: 'Наработка «на глаз»',
    text: 'Ручной перенос данных в журналы и таблицы маскирует фактический износ узлов телесистемы — это приводит к внезапным отказам электроники и дорогостоящему непроизводительному времени.',
  },
  {
    kicker: 'Потеря 03 · искажение сигнала',
    title: 'Ошибки интерпретации',
    text: 'Геомагнитные помехи и механический прогиб инструмента искажают показания датчиков. Без встроенной Sag + SCC-коррекции это повышает риск ухода ствола скважины из продуктивного пласта.',
  },
]

const STATS = [
  { val: 'До 10', label: 'буровых под контролем одного диспетчера одновременно' },
  { val: '30–40%', label: 'снижение затрат на выездной инженерный состав' },
]
---

<section id="economics" data-theme="black">
  <div class="split">
    <div class="split-aside">
      <div class="eyebrow reveal"><span class="ey-no">05<span class="ey-den"> / 09</span></span>Экономика эксплуатации</div>
      <h2 class="split-title reveal">Что стоит разрозненность данных</h2>
      <p class="lead reveal">
        Скрытые дефекты оборудования и разрозненные системы учёта —
        частая причина аварий и незапланированных простоев на буровой.
      </p>
    </div>

    <div class="split-main">
      <div class="econ-problems">
        {PROBLEMS.map((p) => (
          <div class="econ-problem reveal">
            <span class="econ-problem-kicker mono">{p.kicker}</span>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </div>
        ))}
      </div>

      <div class="econ-synergy reveal">
        <span class="econ-synergy-kicker mono">Синергия комплекса</span>
        <h3 class="econ-synergy-title">Скважинные приборы под ИТ-контролем</h3>
        <p class="econ-synergy-text">
          Физическая надёжность оборудования объединена с мгновенной аналитикой
          Drill&nbsp;Monitor: диспетчер в технологическом центре видит те же
          показания, что инженер на площадке, и реагирует на отклонения раньше,
          чем они станут аварией.
        </p>
        <div class="econ-stats">
          {STATS.map((s) => (
            <div class="econ-stat">
              <span class="econ-stat-val mono">{s.val}</span>
              <span class="econ-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
