---
/* «Услуги» — сервисный центр как отдельная тема, которой раньше не было:
   строка «Сервис и ЗИП» в Showcase.astro сворачивает эту тему в одну
   строку линейки, а склад ЗИП и живой ремонт/супервайзинг — разные
   предложения с разным следующим шагом. Секция стоит перед Store.astro нарочно: обе
   про то, что происходит с оборудованием после продажи, и вместе читаются
   одним блоком «сервис → магазин запчастей».

   Первая карточка шире второй (flex-grow 1.4 / 1): ряд из двух
   одинаковых плиток читался бы шаблоном, а не линейкой предложений. */
const SERVICES = [
  {
    n: '01',
    title: 'Модернизация и ТО телесистем',
    text: 'Регламентное техническое обслуживание, калибровка инклинометров, ремонт электронных модулей, замена датчиков и восстановление геометрии корпусов — на собственной сервисной базе.',
    cta: 'Отправить заявку на ремонт',
  },
  {
    n: '02',
    title: 'Онлайн-сопровождение бурения',
    text: 'Развёртывание систем удалённого контроля параметров проходки, предиктивный анализ отклонений и удалённый супервайзинг. Инженер на связи с бригадой круглосуточно.',
    cta: 'Запросить сопровождение',
  },
]
---

<section id="services" data-theme="black">
  <div class="container">
    <div class="car-head">
      <div>
        <div class="eyebrow reveal"><span class="ey-no">07<span class="ey-den"> / 09</span></span>Сервисный центр</div>
        <h2 class="h-title reveal">Услуги</h2>
        <p class="lead reveal">
          Полный цикл инженерно-технической поддержки: от компонентного
          ремонта на собственной базе до онлайн-супервайзинга бурения.
        </p>
      </div>
    </div>
  </div>

  <div class="services-row reveal">
    {SERVICES.map((s, i) => (
      <article class={`services-card ${i === 0 ? 'is-lead' : ''}`}>
        <span class="services-n mono">{s.n} /</span>
        <div class="services-body">
          <h3>{s.title}</h3>
          <p>{s.text}</p>
          <a class="services-link mono" href="#contact">
            {s.cta}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
          </a>
        </div>
      </article>
    ))}
  </div>
</section>
