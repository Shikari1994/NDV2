---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.jsx'
import Hero from '../components/Hero.jsx'
import About from '../components/About.jsx'
import Software from '../components/Software.jsx'
import Showcase from '../components/Showcase.jsx'
import How from '../components/How.jsx'
import Store from '../components/Store.jsx'
import Contact from '../components/Contact.jsx'
import Footer from '../components/Footer.jsx'
import Marquee from '../components/Marquee.jsx'
import Facts from '../components/Facts.jsx'
import Trajectory from '../components/Trajectory.jsx'

const CAPABILITIES = [
  'MWD / LWD', 'Гамма-каротаж', 'Инклинометрия', 'Drill Monitor',
  'Декодирование сигнала', 'Сервис 24/7', 'Реестр отечественного ПО',
]
---

<Layout>
  <div class="bg-fx"></div>

  {/* Без client:load: разметку рисует сервер, поведение — scripts/nav.js.
      Гидратация здесь стоила бы 136 КБ React ради класса и бургера. */}
  <Nav />
  <main id="main">
    <Hero />
    <About />
    <Facts />
    <Software />
    <Marquee items={CAPABILITIES} theme="gray" speed={45} />
    <Showcase />
    <How />
    <Trajectory />
    <Store />
    <Contact />
  </main>
  <Footer />
</Layout>
