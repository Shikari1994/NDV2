---
import { asset } from '../lib/asset.js'

const NAV = [
  ['#about', 'О компании'],
  ['#products', 'Оборудование'],
  ['#software', 'Платформа'],
  ['#how', 'Технологии'],
  ['#services', 'Услуги'],
  ['#store', 'Магазин ЗИП'],
]
---

<footer>
  <div class="container footer-top grid">
    <div class="footer-brand">
      <div class="footer-logo">
        <img src={asset('/logo.webp')} alt="ГЕОТЕХНАВИГАЦИЯ" loading="lazy" />
        <span class="footer-logo-text">Геотехнавигация</span>
      </div>
      <p class="footer-desc">
        Разработка и производство телеметрического оборудования MWD/LWD
        и программного комплекса для геонавигации бурения.
      </p>
    </div>

    <div class="footer-col">
      <h4>Навигация</h4>
      <ul>
        {NAV.map(([href, label]) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Контакты</h4>
      {/* TODO: заменить на реальные контакты */}
      <ul>
        <li><a href="tel:+78000000000">+7 (800) 000-00-00</a></li>
        <li><a href="mailto:info@telemetrylab.ru">info@telemetrylab.ru</a></li>
        <li class="footer-muted">г. Москва, ул. Нефтяников, 1</li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <span class="footer-copy">© 2026 ООО «ГЕОТЕХНАВИГАЦИЯ». Все права защищены.</span>
    <span class="footer-copy footer-muted">ПО в реестре отечественного ПО Минпромторга РФ</span>
  </div>
</footer>
